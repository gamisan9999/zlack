#!/usr/bin/env bash
# Prevent direct push to main. Use PRs instead.
# Install: git config core.hooksPath .githooks

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

while read -r local_ref local_oid remote_ref remote_oid; do
  if echo "$remote_ref" | grep -q "refs/heads/${protected_branch}$"; then
    echo ""
    echo "  BLOCKED: Direct push to '${protected_branch}' is not allowed."
    echo ""
    echo "  Use a PR instead:"
    echo "    git checkout -b feature/my-change"
    echo "    git push origin feature/my-change"
    echo "    gh pr create"
    echo ""
    echo "  To bypass (emergency): git push --no-verify origin main"
    echo ""
    exit 1
  fi
done

exit 0
